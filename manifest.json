{
  "manifest_version": 3,
  "name": "tweetsnap",
  "version": "0.1.0",
  "description": "Add a button to generate images from X/Twitter posts.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": [
    "downloads",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://creator.xiaohongshu.com/*",
    "https://www.instagram.com/*",
    "https://*.cdninstagram.com/*",
    "https://*.fbcdn.net/*",
    "https://react-tweet.vercel.app/*",
    "https://www.tiktok.com/*",
    "https://*.tiktok.com/*",
    "https://*.tiktokcdn.com/*",
    "https://*.tiktokv.com/*",
    "https://*.byteoversea.com/*",
    "https://*.ibytedtos.com/*",
    "https://*.ibyteimg.com/*",
    "https://*.muscdn.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "vendor/dom-to-image.min.js",
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://creator.xiaohongshu.com/*"
      ],
      "js": [
        "xhs-autofill.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "instagram-autofill.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.tiktok.com/*",
        "https://*.tiktok.com/*"
      ],
      "js": [
        "tiktok-autofill.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
